# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/kiranaos?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="24h"

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"

# ─── Next.js Web App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
